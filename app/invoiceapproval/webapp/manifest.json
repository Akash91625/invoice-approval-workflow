{
  "_version": "1.84.0",
  "sap.app": {
    "id": "invoiceapproval",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.23.0",
      "toolsId": "d531efce-551e-4822-9f6e-09bdc85d7a5f"
    },
    "dataSources": {
      "mainService": {
        "uri": "/odata/v4/invoice/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.01"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.147.1",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "invoiceapproval.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "controlAggregation": "pages",
        "controlId": "app",
        "transition": "slide",
        "type": "View",
        "viewType": "XML",
        "path": "invoiceapproval.view",
        "async": true,
        "viewPath": "invoiceapproval.view"
      },
      "routes": [
        {
          "name": "Routeinvoiceapproval",
          "pattern": ":?query:",
          "target": [
            "Targetinvoiceapproval"
          ]
        },
        {
          "name":"RouteDetail",
          "pattern": "detail/{invoiceId}",
          "target":"targetDetail"
        }
      ],
      "targets": {
        "Targetinvoiceapproval": {
          "id": "invoiceapproval",
          "name": "invoiceapproval"
        },
        "targetDetail":{
          "viewName": "invoiceDetail",
          "id": "invoiceDetail",
          "name": "invoiceDetail"
        }
      }
    },
    "rootView": {
      "viewName": "invoiceapproval.view.App",
      "type": "XML",
      "id": "App",
      "async": true
    }
  }
}
